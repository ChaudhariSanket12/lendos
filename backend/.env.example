# ============================================================
# LendOS Backend — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# ============================================================

# --- Database (Supabase PostgreSQL) ---
DB_URL=jdbc:postgresql://<your-supabase-host>:5432/postgres
DB_USERNAME=postgres
DB_PASSWORD=your_supabase_db_password

# --- JWT ---
# Generate a strong 256-bit secret: openssl rand -hex 32
JWT_SECRET=your_super_secret_jwt_key_minimum_256_bits
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# --- Mail (Mailtrap or Mailhog) ---
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Spring Profile ---
SPRING_PROFILES_ACTIVE=dev
